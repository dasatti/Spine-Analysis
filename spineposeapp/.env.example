# ── Infrastructure ────────────────────────────────────────────────
POSTGRES_PASSWORD=changeme_dev
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_BUCKET=spinepose-scans
MINIO_SECURE=false
# Hostname browsers use to load presigned frame URLs (Docker: localhost:9000)
MINIO_PUBLIC_ENDPOINT=localhost:9000

# Database, MinIO, and Redis data persist under ./data/ when using Docker Compose.
# Rebuilds (`docker compose build`) keep data. Do NOT run `docker compose down -v`.

# ── Auth ──────────────────────────────────────────────────────────
JWT_SECRET=replace_with_64_random_chars_minimum_length_for_production_use_here
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ── CORS ──────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000

# ── AI Detection Model ────────────────────────────────────────────
# Set to: spinepose_v2  OR  yolo_v8  OR  yolo_custom
DETECTOR_MODEL=spinepose_v2

# Path to model weights file — required for whichever model is active
# SpinePose:  /path/to/spinepose_v2_weights.pth
# YOLO:       /path/to/yolo_pose.pt
MODEL_WEIGHTS_PATH=

# ── Quality Gate ──────────────────────────────────────────────────
KEYPOINT_CONFIDENCE_THRESHOLD=0.50

# ── AI Spine Classification (side view) ───────────────────────────
# KYPHOSIS_CLASSIFIER_WEIGHTS_PATH=
# LORDOSIS_CLASSIFIER_WEIGHTS_PATH=

# ── AI Scoliosis Detection (back view, YOLO object detection) ─────
# SCOLIOSIS_DETECTOR_WEIGHTS_PATH=
# Lateral deviation index: max keypoint offset / back height (default 0.05)
SCOLIOSIS_LATERAL_INDEX_THRESHOLD=0.05
# Minimum YOLO box confidence for KeyPoint / back detections
SCOLIOSIS_KEYPOINT_CONF_THRESHOLD=0.25
# Minimum KeyPoint boxes required on the back image
SCOLIOSIS_MIN_KEYPOINTS=3

# ── Keypoint Scoliosis Screening (back + Adams pose landmarks) ────
# Scapula asymmetry index above this triggers a positive screen
KEYPOINT_SCOLIOSIS_SCAPULA_THRESHOLD=0.05
# Spine drift (mm) above this triggers a positive screen
KEYPOINT_SCOLIOSIS_SPINE_DRIFT_MM_THRESHOLD=10.0
# Vertebral rotation index above this triggers a positive screen
KEYPOINT_SCOLIOSIS_ROTATION_THRESHOLD=0.03
# Composite signal score (0–1) above this triggers a positive screen
KEYPOINT_SCOLIOSIS_SCORE_THRESHOLD=0.45

# ── Logging ───────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Production HTTPS (Caddy + Let's Encrypt) ──────────────────────
# Leave empty for local HTTP-only reverse proxy on port 80
CADDY_DOMAIN=
ACME_EMAIL=

# ── Database Backups ──────────────────────────────────────────────
MINIO_BACKUP_BUCKET=backups
BACKUP_RETENTION_DAYS=7
BACKUP_INTERVAL_SECONDS=86400
